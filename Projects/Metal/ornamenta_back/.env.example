# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=serviperfiles_db
# Para backend dentro de Docker
DATABASE_URL=postgresql://user:password@db:5432/serviperfiles_db
# Para DataGrip en tu máquina
DATABASE_URL_LOCAL=postgresql://user:password@localhost:5432/serviperfiles_db

# Firebase
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-credentials.json

# Manager seeding
MANAGER_EMAIL=<manager db>
MANAGER_FIREBASE_UID=<firebase-uid>

# Frontend URL para CORS
FRONTEND_URL=http://localhost:5173

# Traefik Basic Auth (solo para producción)
# Protege SOLO documentación: /docs, /redoc, /scalar, /openapi.json
# Los endpoints /admin/* y /roles/* quedan públicos (los consume el frontend)
# Generate with: htpasswd -nbB youruser yourpassword
# IMPORTANTE: Los $ deben escaparse como $$ en el archivo .env
# Ejemplo: admin:$$2y$$05$$JULU2FgF3Bxy5OYBSZYvq.oDc/QY0xzu7xRosGMc3qbSISTDK5KyO
TRAEFIK_DASHBOARD_USERS=admin:$$2y$$05$$JULU2FgF3Bxy5OYBSZYvq.oDc/QY0xzu7xRosGMc3qbSISTDK5KyO
