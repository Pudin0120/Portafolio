# Backup synchronization configuration for Serviperfiles
# Copia este archivo como 'backup_config.env' en la misma carpeta

# User SSH de tu Droplet (ej: alex, root, etc)
REMOTE_USER="alex"

# IP o Dominio de tu servidor DigitalOcean
REMOTE_HOST="REEMPLAZAR_CON_IP_O_DOMINIO"

# Absolute path where backups are stored on the server
REMOTE_PATH="/home/alex/repos/python/serviperfiles_back/backups/"

# Path where you want to store the copy on your local machine
# Puede ser relativa al script o absoluta
LOCAL_PATH="./backups_copy/"
