@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
    @*Easyui*@
    <script type="text/javascript" src="~/Content/jquery-easyui-1.4.5/jquery.min.js"></script>
    <script type="text/javascript" src="~/Content/jquery-easyui-1.4.5/jquery.easyui.min.js"></script>
    <link href="~/Content/jquery-easyui-1.4.5/themes/default/easyui.css" rel="stylesheet" />
    <link href="~/Content/jquery-easyui-1.4.5/themes/icon.css" rel="stylesheet" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="bookmark" href="/favicon.ico" />
    <script src="~/Scripts/jquery.validate.min.js"></script>
    @*cssjs*@
    <link href="~/Content/Site.css" rel="stylesheet" />
    <script src="~/Content/My97DatePicker/WdatePicker.js"></script>
    <script src="~/Content/Site.js"></script>
    <script>
        $(function () {
            InitPhaDialoggrid();
            // InitGrid();
        });

        //DataGird
        function InitGrid() {
            $('#grid').datagrid({
                url: '../InHistory/SearchDetailByPha',
                singleSelect: true,
                fit: true,
                nowrap: true,//
                autoRowHeight: false,
                striped: false,     //
                collapsible: true,      //
                pagination: true,
                pageSize: 20,
                fitColumns: true,       //
                rownumbers: true,
                sortName: 'ID',    //easyUI
                sortOrder: 'asc',
                remoteSort: true,
                loadMsg: '',
                queryParams: ({
                    PhaCode: $('#PhaCode').val(),
                    OrginID: $('#OrginID').val(),
                    startDate: $('#startDate').val(),
                    endDate: $('#endDate').val()
                }),  //
                columns: [[
                     { title: '', field: 'ID', hidden: true },
                     { title: '', field: 'IWID'},
                     { title: '', field: 'Name' },
                     { title: '', field: 'CompanyName' },
                     { title: '', field: 'PhaNo' },
                     { title: '', field: 'InWarehousePrice' },
                     { title: '', field: 'InWarehouseCount', sortable: true, align: 'center' },
                     { title: '', field: 'InWarehouseSum', sortable: true, align: 'center' },
                     { title: '', field: 'IWDate', sortable: true, align: 'center' },
                ]],
                onDblClickRow: function (rowIndex, rowData) {

                },
                onClickRow: function (index, row) {
                    
                }

            })
            var p = $('#grid').datagrid('getPager');
            $(p).pagination({
                pageSize: 20,
                pageList: [10, 12, 20, 40, 60, 100, 200],
                beforePageText: '',
                afterPageText: '    {pages} ',
                displayMsg: ' {from} - {to}     {total} ',
            });
        };


        //
        function InitPhaDialoggrid() {
            $('#phagrid').datagrid({
                url: '../InHistory/SearchPhaListByDate',
                fit: true,
                nowrap: true,//
                autoRowHeight: false,
                singleSelect: true,
                striped: false,     //
                collapsible: true,      //
                pagination: true,
                pageSize: 20,
                fitColumns: true,       //
                rownumbers: true,
                sortName: 'PhaCode',    //easyUI
                sortOrder: 'asc',
                remoteSort: true,
                loadMsg: '',
                queryParams: ({
                    pinyin: $('#phagrid_dir').val(),
                    startDate: $('#startDate').val(),
                    endDate: $('#endDate').val()

                }),  //
                columns: [[
                     { title: '', field: 'PhaCode', hidden: true },
                     { title: '', field: 'OrginID', hidden: true },
                     { title: '', field: 'PhaName', sortable: true },
                     { title: '', field: 'Spec', sortable: true },
                     { title: '', field: 'Unit', sortable: true, },
                     { title: '', field: 'OrginName' },
                     { title: '', field: 'InWarehouseCount' }
                ]],
                toolbar: '#phagrid_tb',
                onDblClickRow: function (rowIndex, rowData) {
                    $('#PhaCode').val(rowData["PhaCode"]);
                    $('#OrginID').val(rowData["OrginID"]);
                    InitGrid();
                }
            })
            var p = $('#phagrid').datagrid('getPager');
            $(p).pagination({
                pageSize: 20,
                pageList: [10, 12, 20, 40, 60, 100, 200],
                beforePageText: '',
                afterPageText: '    {pages} ',
                displayMsg: ' {from} - {to}     {total} ',
            });
        };

    </script>
</head>
<body class="easyui-layout" id="body">
    <div data-options="region:'north',border:false" style="float:left;height:38px;">
        <div class="easyui-panel" style="padding:5px;">
            
            <input type="text" id="startDate" name="startDate" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")" onclick="WdatePicker()" />
            
            <input type="text" id="endDate" name="endDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" onclick="WdatePicker()" />
            <a href="#" class="easyui-linkbutton" data-options="plain:true" onclick="InitPhaDialoggrid()"></a>
        </div>
    </div>
    <div id="left_part" data-options="region:'west',border:true" style="float:left;width:400px;">
        <div id="phaselect">
            <div style="position:fixed;width:400px;height:92%;">
                <table id="phagrid"></table>
            </div>
            <div id="phagrid_tb" style="padding:3px">
                <span>:</span>
                <input id="phagrid_dir" style="border:1px solid #ccc">
                <a href="#" class="easyui-linkbutton" plain="true" onclick="InitPhaDialoggrid()"></a>
            </div>
        </div>
    </div>
    <div data-options="region:'center',border:true" style="float:left">
        <input type="hidden" id="PhaCode" value="" />
        <input type="hidden" id="OrginID" value="" />
        <table id="grid"></table>
    </div>
</body>
</html>
